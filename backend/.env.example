# Docker Compose host bindings
BIND_ADDRESS=192.168.68.62
API_PORT=8787

# Database
POSTGRES_DB=logbook
POSTGRES_USER=logbook
POSTGRES_PASSWORD=replace-with-a-long-random-password
# For local non-Compose development, export DATABASE_URL separately.
DATABASE_POOL_MAX=10

# API authentication. Generate with: openssl rand -hex 32
API_KEY=replace-with-a-long-random-api-key

# Comma-separated browser origins allowed to call the API directly.
# The supplied frontend uses a same-origin reverse proxy and does not require CORS.
CORS_ORIGINS=http://192.168.68.62:8790

HOST=0.0.0.0
PORT=8787
LOG_LEVEL=info
