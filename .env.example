# PostgreSQL
POSTGRES_DB=logbook
POSTGRES_USER=logbook
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_POOL_MAX=10

# Shared backend/frontend API credential. Use at least 16 characters.
API_KEY=replace-with-a-long-random-api-key

# Bind both services to the K11 LAN address so Home Assistant can reach the API
# and browsers can reach the iframe dashboard.
API_BIND_ADDRESS=192.168.68.62
API_PORT=8787
FRONTEND_BIND_ADDRESS=192.168.68.62
FRONTEND_PORT=8790

# Browser access normally goes through the frontend's same-origin proxy, so this
# can remain empty unless another browser application calls the API directly.
CORS_ORIGINS=
LOG_LEVEL=info

# Default reuses the database volume created by the previous backend-only compose.
# Confirm with: docker volume ls | grep logbook
DB_VOLUME_NAME=logbook-backend_logbook-db-pg18
